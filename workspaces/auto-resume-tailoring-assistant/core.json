      "typeVersion": 2,
      "position": [
        0,
        100
      ]
    },
    {
      "parameters": {
        "values": {
          "string": [
            {
              "name": "job_description",
              "value": "Peluang Pekerjaan\nPerusahaan PMA Jepang yang bergerak di manufaktur terkemuka di Indonesia, sedang mencari seorang Programmer Web yang berbakat dan berdedikasi untuk bergabung dengan tim kami. Sebagai Programmer Web, Anda akan memainkan peran kunci dalam mengembangkan dan memelihara solusi web yang inovatif dan fungsional untuk mendukung kegiatan bisnis kami.\n\nTanggung Jawab Utama\nMerancang, mengembangkan, dan mengimplementasikan aplikasi web yang fungsional dan user-friendly\nMenganalisis kebutuhan bisnis dan menterjemahkannya ke dalam spesifikasi teknis\nMengembangkan dan memperbarui situs web perusahaan untuk meningkatkan pengalaman pengguna\nMengintegrasikan aplikasi web dengan sistem dan database back-end\nMelakukan pengujian, debugging, dan pemecahan masalah untuk menjamin kualitas aplikasi\nMemperbarui dan memelihara kode sumber serta dokumentasi teknis\nBerkolaborasi dengan tim desain, produksi, dan manajemen untuk menghasilkan solusi web yang optimal\n\nKualifikasi dan Pengalaman yang Dibutuhkan\nGelar Diploma atau sarjana dalam bidang Teknik Informatika, Sistem Informasi, atau disiplin ilmu terkait\nMemiliki pengalaman minimal 1 tahun sebagai Programmer Web atau posisi serupa\nMahir dalam bahasa pemrograman web seperti PHP, JavaScript, dan Pyhton\nBerpengalaman menggunakan My SQL\nMemahami konsep pengembangan perangkat lunak, arsitektur aplikasi, dan metodologi Agile\nKemampuan analitis yang kuat dan kemampuan pemecahan masalah yang baik\nMemiliki pemahaman yang baik tentang pengoptimalan kinerja dan keamanan web\nKemampuan bekerja dalam tim dan berkomunikasi yang efektif"
            }
          ]
        },
        "options": {}
      },
      "id": "set-jd",
      "name": "Setup Job Deskripsi",
      "type": "n8n-nodes-base.set",
      "typeVersion": 2,
      "position": [
        0,
        300
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const jd = $('Extract Telegram JD').first()?.json?.job_description || $('Setup Job Deskripsi').first()?.json?.job_description || '';\nreturn { json: { job_description: jd } };"
      },
      "id": "merge-jd",
      "name": "Save JD to Context",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        200,
        200
      ]
    },
    {
      "parameters": {
        "method": "PUT",
        "url": "http://qdrant:6333/collections/resume_projects",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{\n  \"vectors\": {\n    \"size\": 768,\n    \"distance\": \"Cosine\"\n  }\n}",
        "options": {}
      },
      "id": "init-qdrant",
      "name": "Init Collection",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
